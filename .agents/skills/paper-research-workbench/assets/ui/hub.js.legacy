(function () {
  const data = JSON.parse(document.getElementById("app-data").textContent);

  const state = {
    query: "",
    topic: "",
    selectedPaperId: data.papers[0] ? data.papers[0].paper_id : null,
    activeTab: document.body.dataset.defaultTab || "overview",
    graphMinScore: 3,
    showAllLabels: true,
    hoveredPaperId: null,
  };

  const paperMap = new Map((data.papers || []).map((paper) => [paper.paper_id, paper]));

  const searchInput = document.getElementById("searchInput");
  const chipbar = document.getElementById("chipbar");
  const paperList = document.getElementById("paperList");
  const generatedAt = document.getElementById("generatedAt");
  const paperCount = document.getElementById("paperCount");
  const edgeCount = document.getElementById("edgeCount");
  const topicCount = document.getElementById("topicCount");
  const ideaCount = document.getElementById("ideaCount");
  const overviewPapers = document.getElementById("overviewPapers");
  const topicList = document.getElementById("topicList");
  const ideaList = document.getElementById("ideaList");
  const detailPanel = document.getElementById("detailPanel");
  const graphDetail = document.getElementById("graphDetail");
  const tabs = Array.from(document.querySelectorAll(".tab"));
  const panels = Array.from(document.querySelectorAll(".panel"));
  const graphCanvas = document.getElementById("graphCanvas");
  const graphStatus = document.getElementById("graphStatus");
  const edgeThresholdInput = document.getElementById("edgeThreshold");
  const edgeThresholdValue = document.getElementById("edgeThresholdValue");
  const toggleLabelsButton = document.getElementById("toggleLabels");
  const resetViewButton = document.getElementById("resetView");
  const ctx = graphCanvas.getContext("2d");
  const themeVars = (() => {
    const style = getComputedStyle(document.documentElement);
    const pick = (name, fallback) => style.getPropertyValue(name).trim() || fallback;
    return {
      graphBg: pick("--graph-bg", "#ffffff"),
      graphLine: pick("--graph-line", "rgba(236, 72, 153, 0.68)"),
      graphNode: pick("--graph-node", "#d4d4d8"),
      graphNodeDim: pick("--graph-node-dim", "#a1a1aa"),
      graphNodeActive: pick("--graph-node-active", "#ec4899"),
      graphText: pick("--graph-text", "#18181b"),
      graphTextDim: pick("--graph-text-dim", "#71717a"),
    };
  })();

  generatedAt.textContent = data.generated_at || "";
  paperCount.textContent = data.paper_count || 0;
  edgeCount.textContent = data.edge_count || 0;
  topicCount.textContent = data.topic_count || 0;
  ideaCount.textContent = data.idea_count || 0;

  function escapeHtml(value) {
    return String(value || "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;");
  }

  function shortLabel(text, maxLen) {
    if (!text || text.length <= maxLen) {
      return text || "";
    }
    return `${text.slice(0, maxLen - 1)}…`;
  }

  function filteredPapers() {
    const query = state.query.trim().toLowerCase();
    return (data.papers || []).filter((paper) => {
      const haystack = [paper.title, ...(paper.tags || []), ...(paper.topics || []), ...(paper.authors || [])]
        .join(" ")
        .toLowerCase();
      if (query && !haystack.includes(query)) {
        return false;
      }
      if (state.topic && !(paper.topics || []).includes(state.topic)) {
        return false;
      }
      return true;
    });
  }

  function setActiveTab(tab) {
    state.activeTab = tab;
    render();
    if (tab === "graph") {
      window.requestAnimationFrame(() => {
        syncCanvasSize();
        drawGraph();
      });
    }
  }

  function selectPaper(paperId, nextTab) {
    if (!paperMap.has(paperId)) {
      return;
    }
    stopGraphMotion();
    state.selectedPaperId = paperId;
    if (nextTab) {
      state.activeTab = nextTab;
    }
    relayoutGraph();
    render();
  }

  function renderTabs() {
    tabs.forEach((tab) => {
      tab.classList.toggle("active", tab.dataset.tab === state.activeTab);
    });
    panels.forEach((panel) => {
      panel.classList.toggle("active", panel.id === `panel-${state.activeTab}`);
    });
  }

  function renderSidebar() {
    const topics = (data.topics || []).slice(0, 8);
    chipbar.innerHTML = [
      `<button class="chip ${state.topic === "" ? "active" : ""}" data-topic="">all</button>`,
      ...topics.map(
        (topic) =>
          `<button class="chip ${state.topic === topic.topic ? "active" : ""}" data-topic="${escapeHtml(topic.topic)}">${escapeHtml(topic.topic)} (${topic.count})</button>`,
      ),
    ].join("");

    chipbar.querySelectorAll(".chip").forEach((button) => {
      button.addEventListener("click", () => {
        state.topic = button.dataset.topic || "";
        render();
      });
    });

    const papers = filteredPapers();
    paperList.innerHTML = papers
      .map(
        (paper) => `
          <div class="paper-item ${state.selectedPaperId === paper.paper_id ? "active" : ""}" data-paper-id="${paper.paper_id}" tabindex="0" role="button" aria-label="打开 ${escapeHtml(paper.title)}">
            <h3>${escapeHtml(shortLabel(paper.title, 58))}</h3>
            <p>${escapeHtml((paper.topics || []).join(" / "))}</p>
          </div>
        `,
      )
      .join("");

    if (!papers.length) {
      paperList.innerHTML = `<div class="paper-item"><p class="subtle">没有匹配的论文，试试清空筛选词。</p></div>`;
    }

    paperList.querySelectorAll(".paper-item[data-paper-id]").forEach((item) => {
      const open = () => selectPaper(item.dataset.paperId, "detail");
      item.addEventListener("click", open);
      item.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          open();
        }
      });
    });
  }

  function renderOverview() {
    overviewPapers.innerHTML = filteredPapers()
      .slice(0, 6)
      .map(
        (paper) => `
          <div class="paper-card" data-paper-id="${paper.paper_id}">
            <div class="section-label">Selected Paper Snapshot</div>
            <h3>${escapeHtml(paper.title)}</h3>
            <p class="subtle">${escapeHtml((paper.authors || []).slice(0, 5).join(", "))}${(paper.authors || []).length > 5 ? " ..." : ""}</p>
            <p class="subtle">${escapeHtml(paper.note_preview || paper.abstract_brief || "暂无预览。")}</p>
            <div class="tagline">${(paper.tags || []).slice(0, 5).map((tag) => `<span class="tag">${escapeHtml(tag)}</span>`).join("")}</div>
            <div class="path-list">
              <a class="path-link" href="${escapeHtml(paper.note_path)}">note.md</a>
              <a class="path-link" href="${escapeHtml(paper.ideas_path)}">ideas.md</a>
            </div>
          </div>
        `,
      )
      .join("");

    overviewPapers.querySelectorAll(".paper-card").forEach((card) => {
      card.addEventListener("click", () => selectPaper(card.dataset.paperId, "detail"));
    });

    topicList.innerHTML = (data.topics || [])
      .map(
        (topic) => `
          <div class="topic-row">
            <div class="section-label">${escapeHtml(topic.topic)}</div>
            <p class="subtle">${topic.count} papers</p>
            <div class="path-list">
              <a class="path-link" href="topic-maps/${escapeHtml(topic.file_name || "")}">open topic map</a>
            </div>
          </div>
        `,
      )
      .join("");
  }

  function renderIdeaList() {
    ideaList.innerHTML = (data.frontier_ideas || [])
      .map(
        (idea, index) => `
          <div class="idea-card">
            <div class="section-label">Frontier Idea ${index + 1}</div>
            <h3>${escapeHtml(idea.title)}</h3>
            <p><strong>Why now:</strong> ${escapeHtml(idea.why_now || "")}</p>
            <p><strong>MVE:</strong> ${escapeHtml(idea.minimum_viable_experiment || "")}</p>
            <p><strong>Gain:</strong> ${escapeHtml(idea.expected_gain || "")}</p>
            <p><strong>Risk:</strong> ${escapeHtml(idea.main_risk || "")}</p>
            <div class="tagline">
              <span class="tag">priority: ${escapeHtml(idea.priority || "")}</span>
              <span class="tag">difficulty: ${escapeHtml(idea.execution_difficulty || "")}</span>
              <span class="tag">topic: ${escapeHtml(idea.topic_anchor || "")}</span>
            </div>
          </div>
        `,
      )
      .join("");
  }

  function renderPaperDetail(target, paper) {
    if (!paper) {
      target.innerHTML = `<div class="surface-card"><p class="subtle">暂无论文。</p></div>`;
      return;
    }

    const neighbors = (paper.neighbors || [])
      .map(
        (neighbor) => `
          <div class="neighbor-card" data-paper-id="${neighbor.paper_id}">
            <div class="section-label">${escapeHtml(shortLabel(neighbor.title, 72))}</div>
            <p class="subtle">score=${neighbor.score} | topic=${escapeHtml((neighbor.shared_topics || []).join(" / "))}</p>
          </div>
        `,
      )
      .join("");

    target.innerHTML = `
      <div class="detail-column">
        <div class="detail-block">
          <div class="section-label">Paper Detail</div>
          <h3>${escapeHtml(paper.title)}</h3>
          <p class="detail-copy">${escapeHtml((paper.authors || []).join(", "))}</p>
          <p class="detail-copy">paper_id: ${escapeHtml(paper.paper_id)} | year: ${escapeHtml(paper.year || "n/a")}</p>
          <p class="detail-copy">${escapeHtml(paper.abstract_brief || "暂无摘要。")}</p>
          <div class="tagline">${(paper.topics || []).map((topic) => `<span class="tag">${escapeHtml(topic)}</span>`).join("")}</div>
          <div class="tagline">${(paper.tags || []).map((tag) => `<span class="tag">${escapeHtml(tag)}</span>`).join("")}</div>
        </div>
        <div class="detail-block">
          <div class="section-label">Editable Files</div>
          <div class="file-grid">
            <a class="file-link" href="${escapeHtml(paper.note_path)}">open note.md</a>
            <a class="file-link" href="${escapeHtml(paper.ideas_path)}">open ideas.md</a>
            <a class="file-link" href="${escapeHtml(paper.feasibility_path)}">open feasibility.md</a>
            <a class="file-link" href="${escapeHtml(paper.ai_node_path)}">open ai node</a>
            ${paper.source_pdf_link ? `<a class="file-link" href="${escapeHtml(paper.source_pdf_link)}">open raw pdf</a>` : ""}
          </div>
        </div>
      </div>
      <div class="neighbor-stack">
        <div class="detail-block">
          <div class="section-label">Current Previews</div>
          <p class="detail-copy">${escapeHtml(paper.note_preview || "暂无笔记预览。")}</p>
          <p class="detail-copy">${escapeHtml(paper.idea_preview || "暂无 idea 预览。")}</p>
          <p class="detail-copy">${escapeHtml(paper.feasibility_preview || "暂无 feasibility 预览。")}</p>
        </div>
        <div class="detail-block">
          <div class="section-label">Nearest Papers</div>
          <div class="stack">${neighbors || "<p class='subtle'>暂无近邻论文。</p>"}</div>
        </div>
      </div>
    `;

    target.querySelectorAll("[data-paper-id]").forEach((item) => {
      item.addEventListener("click", () => selectPaper(item.dataset.paperId, "detail"));
    });
  }

  let graphNodes = [];
  let graphEdges = [];
  let scoreRange = { min: 3, max: 3 };
  const dragState = {
    node: null,
    pointerId: null,
    moved: false,
    offsetX: 0,
    offsetY: 0,
    targetX: 0,
    targetY: 0,
  };
  const motionState = {
    rafId: null,
    lastTs: 0,
    settleTicks: 0,
    isAnimating: false,
  };
  const viewport = {
    width: Number(graphCanvas.getAttribute("width")) || 1280,
    height: Number(graphCanvas.getAttribute("height")) || 820,
    dpr: Math.max(1, window.devicePixelRatio || 1),
    scale: 1,
    panX: 0,
    panY: 0,
    minScale: 0.45,
    maxScale: 2.8,
  };
  const panState = {
    active: false,
    pointerId: null,
    moved: false,
    startX: 0,
    startY: 0,
    startPanX: 0,
    startPanY: 0,
  };

  function clamp(value, min, max) {
    return Math.min(max, Math.max(min, value));
  }

  function syncCanvasSize() {
    const rect = graphCanvas.getBoundingClientRect();
    const hasLayout = rect.width > 8 && rect.height > 8;
    const width = hasLayout ? Math.round(rect.width) : viewport.width;
    const height = hasLayout ? Math.round(rect.height) : viewport.height;
    const dpr = Math.max(1, window.devicePixelRatio || 1);
    const pixelWidth = Math.max(1, Math.round(width * dpr));
    const pixelHeight = Math.max(1, Math.round(height * dpr));

    viewport.width = width;
    viewport.height = height;
    viewport.dpr = dpr;

    if (graphCanvas.width !== pixelWidth || graphCanvas.height !== pixelHeight) {
      graphCanvas.width = pixelWidth;
      graphCanvas.height = pixelHeight;
    }
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function screenToWorld(point) {
    return {
      x: (point.x - viewport.panX) / viewport.scale,
      y: (point.y - viewport.panY) / viewport.scale,
    };
  }

  function resetViewport() {
    viewport.scale = 1;
    viewport.panX = 0;
    viewport.panY = 0;
  }

  function updateCanvasCursor() {
    if (dragState.node) {
      graphCanvas.style.cursor = "grabbing";
      return;
    }
    if (panState.active) {
      graphCanvas.style.cursor = "grabbing";
      return;
    }
    graphCanvas.style.cursor = state.hoveredPaperId ? "pointer" : "grab";
  }

  function requestMotionFrame() {
    if (motionState.rafId !== null) {
      return;
    }
    motionState.rafId = window.requestAnimationFrame(runMotionFrame);
  }

  function kickGraphMotion(ticks) {
    motionState.settleTicks = Math.max(motionState.settleTicks, ticks);
    requestMotionFrame();
  }

  function stopGraphMotion() {
    if (motionState.rafId !== null) {
      window.cancelAnimationFrame(motionState.rafId);
      motionState.rafId = null;
    }
    motionState.lastTs = 0;
    motionState.settleTicks = 0;
    motionState.isAnimating = false;
    graphNodes.forEach((node) => {
      node.vx = 0;
      node.vy = 0;
    });
  }

  function hashText(value) {
    let hash = 2166136261;
    const input = String(value || "");
    for (let i = 0; i < input.length; i += 1) {
      hash ^= input.charCodeAt(i);
      hash = Math.imul(hash, 16777619);
    }
    return hash >>> 0;
  }

  function unitNoise(value, salt) {
    const seed = hashText(`${value}:${salt}`);
    return (seed % 100000) / 100000;
  }

  function buildGraphData() {
    syncCanvasSize();
    graphNodes = (data.papers || []).map((paper, index) => {
      const degree = Math.max((paper.neighbors || []).length, 1);
      return {
        id: paper.paper_id,
        label: paper.title,
        degree,
        radius: 5 + Math.min(degree * 1.1, 6),
        x: 0,
        y: 0,
        vx: 0,
        vy: 0,
        role: "dim",
      };
    });

    const nodeMap = new Map(graphNodes.map((node) => [node.id, node]));
    graphEdges = (data.edges || [])
      .map((edge) => {
        const source = nodeMap.get(edge.source_paper_id);
        const target = nodeMap.get(edge.target_paper_id);
        if (!source || !target) {
          return null;
        }
        return {
          source,
          target,
          score: Number(edge.score || 0),
        };
      })
      .filter(Boolean);

    if (graphEdges.length) {
      scoreRange = {
        min: Math.min(...graphEdges.map((edge) => edge.score)),
        max: Math.max(...graphEdges.map((edge) => edge.score)),
      };
    } else {
      scoreRange = { min: 3, max: 3 };
    }

    const minScore = Math.max(3, Math.floor(scoreRange.min * 2) / 2);
    const maxScore = Math.max(minScore, Math.ceil(scoreRange.max * 2) / 2);
    state.graphMinScore = minScore;

    if (edgeThresholdInput) {
      edgeThresholdInput.min = String(minScore);
      edgeThresholdInput.max = String(maxScore);
      edgeThresholdInput.step = "0.5";
      edgeThresholdInput.value = String(minScore);
    }

    relayoutGraph();
  }

  function visibleEdges() {
    return graphEdges.filter((edge) => edge.score >= state.graphMinScore);
  }

  function relayoutGraph() {
    const width = viewport.width;
    const height = viewport.height;
    const margin = 54;
    if (!graphNodes.length) {
      return;
    }
    if (!state.selectedPaperId || !paperMap.has(state.selectedPaperId)) {
      state.selectedPaperId = graphNodes[0].id;
    }

    const selectedId = state.selectedPaperId;
    const centerX = width * 0.5;
    const centerY = height * 0.34;
    const selectedPaper = paperMap.get(selectedId);
    const neighborIds = new Set((selectedPaper?.neighbors || []).map((item) => item.paper_id));

    graphNodes.forEach((node) => {
      node.role = "dim";
      if (node.id === selectedId) {
        node.role = "selected";
      } else if (neighborIds.has(node.id)) {
        node.role = "neighbor";
      }
    });

    const selectedNode = graphNodes.find((node) => node.id === selectedId);
    if (selectedNode) {
      selectedNode.x = centerX;
      selectedNode.y = centerY;
      selectedNode.vx = 0;
      selectedNode.vy = 0;
      selectedNode.radius = 9;
    }

    const neighbors = graphNodes
      .filter((node) => node.role === "neighbor")
      .sort((left, right) => left.label.localeCompare(right.label));
    const angleStart = -Math.PI * 0.88;
    const angleEnd = Math.PI * 0.12;
    neighbors.forEach((node, index) => {
      const t = neighbors.length <= 1 ? 0.5 : index / (neighbors.length - 1);
      let angle = angleStart + (angleEnd - angleStart) * t;
      if (neighbors.length >= 4 && index === neighbors.length - 1) {
        angle = Math.PI * 0.48;
      }
      const radius = index === neighbors.length - 1 && neighbors.length >= 4 ? 248 : 216 + (index % 2) * 20;
      node.x = centerX + Math.cos(angle) * radius;
      node.y = centerY + Math.sin(angle) * radius;
      node.vx = 0;
      node.vy = 0;
      node.radius = 7;
    });

    graphNodes
      .filter((node) => node.role === "dim")
      .forEach((node, index) => {
        const nx = margin + unitNoise(node.id, index + 17) * (width - margin * 2);
        const ny = margin + unitNoise(node.id, index + 41) * (height - margin * 2);
        let x = nx;
        let y = ny;
        const dx = x - centerX;
        const dy = y - centerY;
        const dist = Math.hypot(dx, dy);
        if (dist < 196) {
          const safe = 196 + unitNoise(node.id, 73) * 90;
          const scale = safe / Math.max(1, dist);
          x = centerX + dx * scale;
          y = centerY + dy * scale;
        }
        node.x = Math.min(width - margin, Math.max(margin, x));
        node.y = Math.min(height - margin, Math.max(margin, y));
        node.vx = 0;
        node.vy = 0;
        node.radius = 6;
      });
    motionState.settleTicks = 0;
  }

  function simulateGraphStep(dt) {
    if (!graphNodes.length) {
      return false;
    }

    const width = viewport.width;
    const height = viewport.height;
    const scale = clamp(dt * 60, 0.45, 1.8);
    const draggedNode = dragState.node;
    const damping = 0.86;
    const springBase = 0.018;
    const repulsionBase = 780;
    const gravity = 0.0019;
    const edgeList = visibleEdges();
    const scoreSpan = Math.max(0.001, scoreRange.max - scoreRange.min);
    const boundsPadding = 14;

    graphNodes.forEach((node) => {
      node.ax = 0;
      node.ay = 0;
    });

    edgeList.forEach((edge) => {
      const dx = edge.target.x - edge.source.x;
      const dy = edge.target.y - edge.source.y;
      const dist = Math.max(0.001, Math.hypot(dx, dy));
      const ux = dx / dist;
      const uy = dy / dist;
      const scoreNorm = (edge.score - scoreRange.min) / scoreSpan;
      const restLength = 128 - scoreNorm * 44;
      const spring = springBase + scoreNorm * 0.017;
      const force = (dist - restLength) * spring;
      const fx = ux * force;
      const fy = uy * force;

      if (edge.source !== draggedNode) {
        edge.source.ax += fx;
        edge.source.ay += fy;
      }
      if (edge.target !== draggedNode) {
        edge.target.ax -= fx;
        edge.target.ay -= fy;
      }
    });

    for (let i = 0; i < graphNodes.length; i += 1) {
      const a = graphNodes[i];
      for (let j = i + 1; j < graphNodes.length; j += 1) {
        const b = graphNodes[j];
        const dx = b.x - a.x;
        const dy = b.y - a.y;
        const distSq = dx * dx + dy * dy + 0.01;
        if (distSq > 220000) {
          continue;
        }
        const dist = Math.sqrt(distSq);
        const force = repulsionBase / distSq;
        const fx = (dx / dist) * force;
        const fy = (dy / dist) * force;

        if (a !== draggedNode) {
          a.ax -= fx;
          a.ay -= fy;
        }
        if (b !== draggedNode) {
          b.ax += fx;
          b.ay += fy;
        }
      }
    }

    const centerX = width * 0.5;
    const centerY = height * 0.45;
    graphNodes.forEach((node) => {
      if (node === draggedNode) {
        return;
      }
      node.ax += (centerX - node.x) * gravity;
      node.ay += (centerY - node.y) * gravity;
    });

    graphNodes.forEach((node) => {
      const grip = Math.max(boundsPadding, node.radius + 4);

      if (node === draggedNode) {
        node.x = clamp(dragState.targetX, grip, width - grip);
        node.y = clamp(dragState.targetY, grip, height - grip);
        node.vx = 0;
        node.vy = 0;
        return;
      }

      node.vx = (node.vx + node.ax * scale) * damping;
      node.vy = (node.vy + node.ay * scale) * damping;
      node.x += node.vx * scale;
      node.y += node.vy * scale;

      if (node.x < grip) {
        node.x = grip;
        node.vx *= -0.2;
      } else if (node.x > width - grip) {
        node.x = width - grip;
        node.vx *= -0.2;
      }

      if (node.y < grip) {
        node.y = grip;
        node.vy *= -0.2;
      } else if (node.y > height - grip) {
        node.y = height - grip;
        node.vy *= -0.2;
      }

      const speed = Math.hypot(node.vx, node.vy);
      if (speed < 0.003) {
        node.vx = 0;
        node.vy = 0;
      }
    });

    if (!draggedNode && motionState.settleTicks > 0) {
      motionState.settleTicks -= 1;
    }

    if (draggedNode) {
      return true;
    }
    return motionState.settleTicks > 0;
  }

  function runMotionFrame(timestamp) {
    motionState.rafId = null;
    motionState.isAnimating = true;
    const last = motionState.lastTs || timestamp - 16;
    const dt = clamp((timestamp - last) / 1000, 0.008, 0.034);
    motionState.lastTs = timestamp;

    const active = simulateGraphStep(dt);
    drawGraph();

    if (active) {
      requestMotionFrame();
      return;
    }
    stopGraphMotion();
  }

  function spotlightEdges() {
    const edges = visibleEdges();
    if (!state.selectedPaperId) {
      return edges.slice(0, 12);
    }
    const focused = edges.filter(
      (edge) => edge.source.id === state.selectedPaperId || edge.target.id === state.selectedPaperId,
    );
    if (focused.length) {
      return focused;
    }
    return edges.slice(0, 12);
  }

  function selectedNeighborIds() {
    const selected = paperMap.get(state.selectedPaperId);
    if (!selected) {
      return new Set();
    }
    const ids = new Set([selected.paper_id]);
    (selected.neighbors || []).forEach((neighbor) => ids.add(neighbor.paper_id));
    return ids;
  }

  function drawGraph() {
    syncCanvasSize();
    const width = viewport.width;
    const height = viewport.height;
    const edges = spotlightEdges();
    const focusIds = selectedNeighborIds();
    const selectedNode = graphNodes.find((node) => node.id === state.selectedPaperId);

    ctx.setTransform(viewport.dpr, 0, 0, viewport.dpr, 0, 0);
    ctx.clearRect(0, 0, width, height);
    ctx.fillStyle = themeVars.graphBg;
    ctx.fillRect(0, 0, width, height);
    const spotlightX = selectedNode ? selectedNode.x * viewport.scale + viewport.panX : width * 0.5;
    const spotlightY = selectedNode ? selectedNode.y * viewport.scale + viewport.panY : height * 0.34;
    const spotlight = ctx.createRadialGradient(spotlightX, spotlightY, 30, spotlightX, spotlightY, 360);
    spotlight.addColorStop(0, "rgba(236, 72, 153, 0.11)");
    spotlight.addColorStop(1, "rgba(236, 72, 153, 0)");
    ctx.fillStyle = spotlight;
    ctx.fillRect(0, 0, width, height);

    ctx.save();
    ctx.translate(viewport.panX, viewport.panY);
    ctx.scale(viewport.scale, viewport.scale);

    edges.forEach((edge) => {
      const hasFocus = edge.source.id === state.selectedPaperId || edge.target.id === state.selectedPaperId;
      const scoreScale =
        scoreRange.max > scoreRange.min ? (edge.score - scoreRange.min) / (scoreRange.max - scoreRange.min) : 1;
      ctx.lineWidth = (hasFocus ? 1.1 + scoreScale * 1.25 : 0.5) / viewport.scale;
      ctx.strokeStyle = hasFocus ? themeVars.graphLine : "rgba(161, 161, 170, 0.18)";
      const mx = (edge.source.x + edge.target.x) / 2;
      const my = (edge.source.y + edge.target.y) / 2;
      ctx.beginPath();
      ctx.moveTo(edge.source.x, edge.source.y);
      ctx.quadraticCurveTo(mx, my, edge.target.x, edge.target.y);
      ctx.stroke();
    });

    graphNodes.forEach((node) => {
      const selected = node.id === state.selectedPaperId;
      const hovered = node.id === state.hoveredPaperId;
      const neighbor = focusIds.has(node.id) && !selected;
      const radius = node.radius + (selected ? 1.5 : 0) + (hovered ? 0.8 : 0);

      if (selected || hovered) {
        ctx.beginPath();
        ctx.fillStyle = selected ? "rgba(236, 72, 153, 0.22)" : "rgba(244, 63, 94, 0.11)";
        ctx.arc(node.x, node.y, radius + 7, 0, Math.PI * 2);
        ctx.fill();
      }

      ctx.beginPath();
      ctx.fillStyle = selected ? themeVars.graphNodeActive : neighbor ? themeVars.graphNode : themeVars.graphNodeDim;
      ctx.strokeStyle = selected
        ? "rgba(190, 24, 93, 0.95)"
        : neighbor
          ? "rgba(212, 212, 216, 0.95)"
          : "rgba(161, 161, 170, 0.9)";
      ctx.lineWidth = (selected ? 1.4 : 1) / viewport.scale;
      ctx.arc(node.x, node.y, radius, 0, Math.PI * 2);
      ctx.fill();
      ctx.stroke();

      const showLabel = state.showAllLabels || selected || hovered || neighbor;
      if (showLabel) {
        const label = shortLabel(node.label, selected ? 40 : 34);
        ctx.textAlign = "center";
        ctx.textBaseline = "top";
        ctx.font = selected ? "600 13px Inter" : neighbor ? "500 12px Inter" : "500 11px Inter";
        ctx.fillStyle = selected ? "#9d174d" : neighbor ? themeVars.graphText : themeVars.graphTextDim;
        const yOffset = selected ? 12 : 11;
        ctx.fillText(label, node.x, node.y + radius + yOffset);
      }
    });
    ctx.restore();

    if (graphStatus) {
      const selectedTitle = paperMap.get(state.selectedPaperId)?.title || "未选择";
      graphStatus.textContent = `edges visible ${edges.length}/${graphEdges.length} | selected ${shortLabel(selectedTitle, 42)} | zoom ${viewport.scale.toFixed(2)}x`;
    }

    updateCanvasCursor();
    if ((!dragState.node || !dragState.moved) && !panState.active && !motionState.isAnimating) {
      renderPaperDetail(graphDetail, paperMap.get(state.selectedPaperId));
    }
  }

  function getCanvasPoint(event) {
    const rect = graphCanvas.getBoundingClientRect();
    return {
      x: event.clientX - rect.left,
      y: event.clientY - rect.top,
    };
  }

  function closestNode(point, maxDistanceScreen) {
    const maxDistance = maxDistanceScreen / viewport.scale;
    let best = null;
    let bestDistance = Infinity;
    graphNodes.forEach((node) => {
      const distance = Math.hypot(node.x - point.x, node.y - point.y);
      if (distance < bestDistance) {
        bestDistance = distance;
        best = node;
      }
    });
    if (!best || bestDistance > maxDistance) {
      return null;
    }
    return best;
  }

  function updateHover(screenPoint) {
    const worldPoint = screenToWorld(screenPoint);
    const node = closestNode(worldPoint, 30);
    const nextHoveredId = node ? node.id : null;
    if (nextHoveredId !== state.hoveredPaperId) {
      state.hoveredPaperId = nextHoveredId;
      updateCanvasCursor();
      drawGraph();
      return true;
    }
    return false;
  }

  function beginPan(event, point) {
    panState.active = true;
    panState.pointerId = event.pointerId;
    panState.moved = false;
    panState.startX = point.x;
    panState.startY = point.y;
    panState.startPanX = viewport.panX;
    panState.startPanY = viewport.panY;
    graphCanvas.setPointerCapture(event.pointerId);
    updateCanvasCursor();
  }

  function finishPan(event) {
    if (!panState.active || event.pointerId !== panState.pointerId) {
      return false;
    }
    panState.active = false;
    panState.pointerId = null;
    panState.moved = false;
    panState.startX = 0;
    panState.startY = 0;
    panState.startPanX = 0;
    panState.startPanY = 0;
    try {
      graphCanvas.releasePointerCapture(event.pointerId);
    } catch (error) {}
    updateCanvasCursor();
    return true;
  }

  graphCanvas.addEventListener("pointerdown", (event) => {
    const screenPoint = getCanvasPoint(event);
    const worldPoint = screenToWorld(screenPoint);
    const node = closestNode(worldPoint, 34);
    if (!node) {
      beginPan(event, screenPoint);
      drawGraph();
      event.preventDefault();
      return;
    }
    dragState.node = node;
    dragState.pointerId = event.pointerId;
    dragState.moved = false;
    dragState.offsetX = worldPoint.x - node.x;
    dragState.offsetY = worldPoint.y - node.y;
    dragState.targetX = node.x;
    dragState.targetY = node.y;
    state.hoveredPaperId = node.id;
    state.selectedPaperId = node.id;
    motionState.settleTicks = 0;
    updateCanvasCursor();
    graphCanvas.setPointerCapture(event.pointerId);
    drawGraph();
    event.preventDefault();
  });

  graphCanvas.addEventListener("pointermove", (event) => {
    const screenPoint = getCanvasPoint(event);
    if (!dragState.node || event.pointerId !== dragState.pointerId) {
      if (panState.active && event.pointerId === panState.pointerId) {
        const dx = screenPoint.x - panState.startX;
        const dy = screenPoint.y - panState.startY;
        if (Math.hypot(dx, dy) > 1.2) {
          panState.moved = true;
        }
        viewport.panX = panState.startPanX + dx;
        viewport.panY = panState.startPanY + dy;
        updateCanvasCursor();
        drawGraph();
        event.preventDefault();
        return;
      }
      updateHover(screenPoint);
      return;
    }

    const worldPoint = screenToWorld(screenPoint);
    const width = viewport.width;
    const height = viewport.height;
    const grip = Math.max(12, dragState.node.radius + 6);
    const nextX = clamp(worldPoint.x - dragState.offsetX, grip, width - grip);
    const nextY = clamp(worldPoint.y - dragState.offsetY, grip, height - grip);
    if (Math.hypot(nextX - dragState.targetX, nextY - dragState.targetY) > 0.8) {
      dragState.moved = true;
    }
    dragState.targetX = nextX;
    dragState.targetY = nextY;
    state.hoveredPaperId = dragState.node.id;
    updateCanvasCursor();
    if (dragState.moved) {
      requestMotionFrame();
    }
    event.preventDefault();
  });

  function finishDrag(event) {
    if (!dragState.node || event.pointerId !== dragState.pointerId) {
      return false;
    }
    const releasedNode = dragState.node;
    const moved = dragState.moved;
    dragState.node = null;
    dragState.pointerId = null;
    dragState.moved = false;
    dragState.offsetX = 0;
    dragState.offsetY = 0;
    dragState.targetX = 0;
    dragState.targetY = 0;
    try {
      graphCanvas.releasePointerCapture(event.pointerId);
    } catch (error) {}

    if (!moved) {
      stopGraphMotion();
      selectPaper(releasedNode.id, "graph");
      return true;
    }
    state.hoveredPaperId = releasedNode.id;
    updateCanvasCursor();
    kickGraphMotion(32);
    return true;
  }

  function finishPointer(event) {
    if (finishDrag(event)) {
      return;
    }
    finishPan(event);
  }

  graphCanvas.addEventListener("pointerup", finishPointer);
  graphCanvas.addEventListener("pointercancel", finishPointer);

  graphCanvas.addEventListener(
    "wheel",
    (event) => {
      const point = getCanvasPoint(event);
      const worldBefore = screenToWorld(point);
      const zoomFactor = Math.exp(-event.deltaY * 0.0014);
      const nextScale = clamp(viewport.scale * zoomFactor, viewport.minScale, viewport.maxScale);
      if (nextScale === viewport.scale) {
        return;
      }
      viewport.scale = nextScale;
      viewport.panX = point.x - worldBefore.x * viewport.scale;
      viewport.panY = point.y - worldBefore.y * viewport.scale;
      drawGraph();
      event.preventDefault();
    },
    { passive: false },
  );

  graphCanvas.addEventListener("pointerleave", () => {
    if (dragState.node || panState.active) {
      return;
    }
    if (state.hoveredPaperId !== null) {
      state.hoveredPaperId = null;
      updateCanvasCursor();
      drawGraph();
    }
  });

  function syncGraphControls() {
    if (edgeThresholdValue) {
      edgeThresholdValue.textContent = state.graphMinScore.toFixed(1);
    }
    if (toggleLabelsButton) {
      toggleLabelsButton.textContent = `Labels: ${state.showAllLabels ? "All" : "Focus"}`;
      toggleLabelsButton.classList.toggle("active", state.showAllLabels);
    }
  }

  function render() {
    renderTabs();
    renderSidebar();
    renderOverview();
    renderIdeaList();
    renderPaperDetail(detailPanel, paperMap.get(state.selectedPaperId));
    syncGraphControls();
    drawGraph();
  }

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => setActiveTab(tab.dataset.tab));
  });

  searchInput.addEventListener("input", () => {
    state.query = searchInput.value;
    render();
  });

  if (edgeThresholdInput) {
    edgeThresholdInput.addEventListener("input", () => {
      state.graphMinScore = Number(edgeThresholdInput.value || state.graphMinScore);
      render();
    });
  }

  if (toggleLabelsButton) {
    toggleLabelsButton.addEventListener("click", () => {
      state.showAllLabels = !state.showAllLabels;
      render();
    });
  }

  if (resetViewButton) {
    resetViewButton.addEventListener("click", () => {
      resetViewport();
      drawGraph();
    });
  }

  window.addEventListener("resize", () => {
    syncCanvasSize();
    drawGraph();
  });

  resetViewport();
  buildGraphData();
  render();
})();
