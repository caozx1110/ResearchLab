@import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;700&family=Playfair+Display:wght@500;600;700&display=swap");

:root {
  --bg: #f5f5f5;
  --panel: #ffffff;
  --panel-soft: #fafafa;
  --ink: #18181b;
  --ink-soft: #3f3f46;
  --muted: #52525b;
  --muted-soft: #71717a;
  --line: #e4e4e7;
  --line-strong: #d4d4d8;
  --accent: #ec4899;
  --accent-soft: rgba(236, 72, 153, 0.1);
  --accent-ink: #be185d;
  --radius-sm: 14px;
  --radius-md: 20px;
  --radius-lg: 28px;
  --shadow-soft: 0 10px 26px rgba(24, 24, 27, 0.06);
  --graph-bg: #ffffff;
  --graph-surface: #ffffff;
  --graph-line: rgba(236, 72, 153, 0.68);
  --graph-node: #d4d4d8;
  --graph-node-dim: #a1a1aa;
  --graph-node-active: #ec4899;
  --graph-text: #18181b;
  --graph-text-dim: #71717a;
}

* {
  box-sizing: border-box;
}

html,
body {
  min-height: 100%;
}

body {
  margin: 0;
  color: var(--ink);
  font-family: "Inter", "Helvetica Neue", sans-serif;
  background:
    radial-gradient(circle at 100% 0%, rgba(236, 72, 153, 0.08), transparent 28%),
    radial-gradient(circle at 0% 100%, rgba(24, 24, 27, 0.05), transparent 38%),
    linear-gradient(180deg, #ffffff 0%, var(--bg) 100%);
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input {
  font: inherit;
}

.app-shell {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 312px 1fr;
}

.rail {
  position: sticky;
  top: 0;
  height: 100vh;
  overflow: auto;
  padding: 22px 18px 24px;
  border-right: 1px solid var(--line);
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(18px);
}

.rail-card,
.surface-card,
.stat-card {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-soft);
}

.brand-card {
  padding: 20px;
  border-radius: var(--radius-lg);
  margin-bottom: 16px;
}

.eyebrow,
.stat-label,
.section-label,
.meta-line,
.graph-note,
.graph-status,
.range-wrap {
  font-family: "JetBrains Mono", monospace;
}

.eyebrow {
  margin: 0 0 8px;
  color: var(--muted-soft);
  font-size: 11px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.brand-card h1 {
  margin: 0 0 10px;
  font-family: "Playfair Display", serif;
  font-size: clamp(2.45rem, 3vw, 3.35rem);
  line-height: 0.93;
  letter-spacing: -0.03em;
}

.brand-copy {
  margin: 0;
  color: var(--muted);
  font-size: 14px;
  line-height: 1.65;
}

.search-input {
  width: 100%;
  border-radius: 999px;
  border: 1px solid var(--line);
  background: #ffffff;
  color: var(--ink);
  padding: 12px 14px;
  margin-bottom: 14px;
  transition: border-color 180ms ease, box-shadow 180ms ease;
}

.search-input:focus {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(236, 72, 153, 0.18);
}

.chipbar {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}

.chip {
  cursor: pointer;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: #ffffff;
  color: var(--muted);
  padding: 7px 11px;
  font-size: 12px;
  transition: all 180ms ease;
}

.chip:hover,
.chip.active {
  border-color: var(--ink);
  background: var(--ink);
  color: #ffffff;
}

.rail-section {
  display: grid;
  gap: 10px;
}

.paper-list,
.stack,
.topic-list,
.path-list,
.idea-list,
.detail-card,
.neighbor-stack,
.detail-column,
.file-grid {
  display: grid;
  gap: 12px;
}

.paper-item,
.paper-card,
.topic-row,
.idea-card,
.neighbor-card,
.detail-block {
  border: 1px solid var(--line);
  border-radius: 18px;
  background: var(--panel);
  padding: 14px;
  transition: border-color 180ms ease, background-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
}

.paper-item,
.paper-card,
.topic-row,
.neighbor-card {
  cursor: pointer;
}

.paper-item:hover,
.paper-card:hover,
.topic-row:hover,
.neighbor-card:hover,
.idea-card:hover {
  transform: translateY(-1px);
  border-color: var(--line-strong);
}

.paper-item.active {
  border-color: var(--accent);
  box-shadow: 0 0 0 2px rgba(236, 72, 153, 0.14);
}

.paper-item h3,
.paper-card h3,
.idea-card h3,
.detail-card h3 {
  margin: 0 0 8px;
  font-size: 16px;
  line-height: 1.35;
}

.paper-item p,
.subtle {
  margin: 0;
  color: var(--muted);
  font-size: 13px;
  line-height: 1.6;
}

.main {
  padding: 28px;
  display: grid;
  gap: 18px;
}

.hero {
  display: flex;
  justify-content: space-between;
  align-items: end;
  gap: 20px;
}

.hero h2 {
  margin: 0 0 12px;
  font-family: "Playfair Display", serif;
  font-size: clamp(3rem, 7vw, 6.1rem);
  line-height: 0.9;
  letter-spacing: -0.04em;
}

.hero-copy {
  max-width: 780px;
  margin: 0;
  color: var(--muted);
  font-size: 16px;
  line-height: 1.68;
}

.hero-links {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.hero-link,
.path-link,
.file-link {
  cursor: pointer;
  border-radius: 999px;
  border: 1px solid var(--line);
  background: #ffffff;
  padding: 10px 12px;
  transition: all 180ms ease;
}

.hero-link:hover,
.path-link:hover,
.file-link:hover {
  border-color: var(--accent);
  background: var(--accent);
  color: #ffffff;
}

.stats-grid {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.stat-card {
  padding: 16px;
}

.stat-label {
  color: var(--muted-soft);
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}

.stat-value {
  margin-top: 6px;
  font-size: 32px;
  line-height: 1;
  font-weight: 800;
}

.meta-line {
  color: var(--muted);
  font-size: 12px;
}

.tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tab {
  cursor: pointer;
  border-radius: 999px;
  border: 1px solid var(--line);
  background: #ffffff;
  color: var(--muted);
  padding: 10px 14px;
  transition: all 180ms ease;
}

.tab:hover,
.tab.active {
  border-color: var(--ink);
  background: var(--ink);
  color: #ffffff;
}

.tab.compact {
  padding: 8px 12px;
  font-size: 12px;
}

.panel {
  display: none;
}

.panel.active {
  display: block;
}

.panel-grid,
.graph-layout,
.detail-layout {
  display: grid;
  gap: 14px;
  grid-template-columns: minmax(0, 1.12fr) minmax(320px, 0.88fr);
}

.surface-card {
  padding: 16px;
  border-radius: var(--radius-md);
}

.tagline {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 10px;
}

.tag {
  border-radius: 999px;
  border: 1px solid var(--line);
  background: var(--panel-soft);
  padding: 4px 8px;
  font-size: 12px;
  color: var(--muted);
}

.path-list {
  margin-top: 10px;
}

.graph-card {
  min-height: 690px;
  border-radius: var(--radius-lg);
  background: linear-gradient(180deg, rgba(236, 72, 153, 0.04), rgba(255, 255, 255, 0)),
    var(--graph-surface);
  border-color: var(--line);
  box-shadow: var(--shadow-soft);
}

.graph-head {
  display: flex;
  justify-content: space-between;
  align-items: end;
  gap: 14px;
  margin-bottom: 12px;
}

.graph-tools {
  display: grid;
  gap: 8px;
  justify-items: end;
  min-width: 280px;
}

.range-wrap {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  color: var(--muted-soft);
  font-size: 11px;
  letter-spacing: 0.02em;
  text-transform: uppercase;
}

#edgeThresholdValue {
  color: var(--accent-ink);
  font-weight: 700;
}

.range-input {
  width: 100%;
  cursor: pointer;
  accent-color: var(--accent);
}

.graph-note {
  color: var(--muted);
  font-size: 12px;
}

.graph-status {
  margin-bottom: 10px;
  color: var(--muted-soft);
  font-size: 11px;
  letter-spacing: 0.02em;
}

canvas {
  width: 100%;
  height: 620px;
  display: block;
  border: 1px solid var(--line);
  border-radius: 22px;
  background: radial-gradient(circle at 52% 36%, rgba(236, 72, 153, 0.08), transparent 44%),
    radial-gradient(circle at 16% 84%, rgba(236, 72, 153, 0.04), transparent 40%),
    var(--graph-bg);
  touch-action: none;
  cursor: default;
}

.detail-block {
  background: #ffffff;
}

.detail-copy {
  margin: 0;
  color: var(--muted);
  line-height: 1.72;
}

.idea-card p {
  margin: 0 0 10px;
  color: var(--muted);
  line-height: 1.7;
}

#graphDetail {
  background: linear-gradient(180deg, rgba(236, 72, 153, 0.04), rgba(255, 255, 255, 0)),
    var(--graph-surface);
  border-color: var(--line);
  box-shadow: var(--shadow-soft);
}

#graphDetail .detail-block,
#graphDetail .neighbor-card {
  background: #ffffff;
  border-color: var(--line);
}

#graphDetail h3,
#graphDetail .section-label {
  color: var(--graph-text);
}

#graphDetail .detail-copy,
#graphDetail .subtle {
  color: var(--graph-text-dim);
}

#graphDetail .tag {
  background: var(--panel-soft);
  border-color: var(--line);
  color: var(--muted);
}

#graphDetail .file-link {
  background: #ffffff;
  border-color: var(--line);
  color: var(--ink);
}

#graphDetail .file-link:hover {
  border-color: var(--accent);
  background: var(--accent);
  color: #ffffff;
}

.graph-card .tab.compact {
  border-color: var(--line);
  background: #ffffff;
  color: var(--muted);
}

.graph-card .tab.compact:hover,
.graph-card .tab.compact.active {
  border-color: var(--accent);
  background: var(--accent);
  color: #ffffff;
}

input[type="range"]:focus-visible,
button:focus-visible,
a:focus-visible,
.paper-item:focus-visible,
.paper-card:focus-visible,
.neighbor-card:focus-visible {
  outline: 2px solid rgba(236, 72, 153, 0.28);
  outline-offset: 2px;
}

@media (max-width: 1280px) {
  .graph-head {
    align-items: start;
    flex-direction: column;
  }

  .graph-tools {
    width: 100%;
    justify-items: stretch;
  }
}

@media (max-width: 1180px) {
  .app-shell {
    grid-template-columns: 1fr;
  }

  .rail {
    position: static;
    height: auto;
    border-right: none;
    border-bottom: 1px solid var(--line);
  }

  .hero,
  .panel-grid,
  .graph-layout,
  .detail-layout,
  .stats-grid {
    grid-template-columns: 1fr;
  }

  .hero h2 {
    font-size: clamp(2.8rem, 12vw, 4.2rem);
  }
}

@media (max-width: 640px) {
  .main {
    padding: 16px;
  }

  .rail {
    padding: 16px;
  }

  .brand-card h1 {
    font-size: clamp(2.2rem, 12vw, 2.7rem);
  }

  canvas {
    height: 480px;
  }

  .tab,
  .hero-link,
  .path-link,
  .file-link {
    width: 100%;
    text-align: center;
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation: none !important;
    transition-duration: 0ms !important;
    scroll-behavior: auto !important;
  }
}
